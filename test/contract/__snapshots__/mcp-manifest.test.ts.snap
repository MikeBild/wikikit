exports[`MCP manifest contract tools/list manifest for read-key 1`] = `
[
  {
    "annotations": {
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false,
      "readOnlyHint": true,
    },
    "description": "Ranked full-text search over the knowledge base (current concept revisions and visible claims). Returns raw evidence with <mark> headlines — no synthesis. Use wikikit_read to fetch a full concept.",
    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "description": "Restrict hits to one kind",
          "enum": [
            "concept",
            "claim",
          ],
          "type": "string",
        },
        "limit": {
          "description": "Max hits (default 20)",
          "maximum": 50,
          "minimum": 1,
          "type": "integer",
        },
        "q": {
          "description": "Full-text query",
          "maxLength": 1000,
          "minLength": 1,
          "type": "string",
        },
        "space": {
          "description": "Space slug the key is working in",
          "pattern": "^[a-z0-9][a-z0-9-]{0,62}$",
          "type": "string",
        },
      },
      "required": [
        "space",
        "q",
      ],
      "type": "object",
      "~standard": {
        "jsonSchema": {
          "input": [Function],
          "output": [Function],
        },
        "validate": [Function],
        "vendor": "zod",
        "version": 1,
      },
    },
    "name": "wikikit_search",
  },
  {
    "annotations": {
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false,
      "readOnlyHint": true,
    },
    "description": "Read one concept completely: markdown, verified/disputed claims with citations, relations, current revision number and agent_meta provenance.",
    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "slug": {
          "pattern": "^[a-z0-9][a-z0-9-]{0,126}$",
          "type": "string",
        },
        "space": {
          "description": "Space slug the key is working in",
          "pattern": "^[a-z0-9][a-z0-9-]{0,62}$",
          "type": "string",
        },
      },
      "required": [
        "space",
        "slug",
      ],
      "type": "object",
      "~standard": {
        "jsonSchema": {
          "input": [Function],
          "output": [Function],
        },
        "validate": [Function],
        "vendor": "zod",
        "version": 1,
      },
    },
    "name": "wikikit_read",
  },
  {
    "annotations": {
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false,
      "readOnlyHint": true,
    },
    "description": "Provenance chain down to the original sources. Pass a concept slug to list every source its visible claims cite, or a source_id to inspect one archived source.",
    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "slug": {
          "description": "Concept slug — lists the sources its claims cite",
          "pattern": "^[a-z0-9][a-z0-9-]{0,126}$",
          "type": "string",
        },
        "source_id": {
          "description": "Single source id to inspect",
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
          "type": "string",
        },
        "space": {
          "description": "Space slug the key is working in",
          "pattern": "^[a-z0-9][a-z0-9-]{0,62}$",
          "type": "string",
        },
      },
      "required": [
        "space",
      ],
      "type": "object",
