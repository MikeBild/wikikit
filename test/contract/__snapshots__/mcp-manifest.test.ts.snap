exports[`MCP manifest contract tools/list manifest for propose-key 1`] = `
[
  {
    "annotations": {
      "destructiveHint": true,
      "idempotentHint": true,
      "openWorldHint": true,
      "readOnlyHint": false,
    },
    "description": "Submit a source (markdown, text, or a URL to fetch) into the ingest pipeline. Returns an async handle immediately — ALWAYS poll wikikit_ingest_status with the returned ingest_id; never wait in-band. The result is a pending ChangeProposal that a human approves over REST.",
    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "markdown": {
          "minLength": 1,
          "type": "string",
        },
        "source_kind": {
          "description": "What the source is: 'meeting' sources are mined for explicit decision statements",
          "enum": [
            "meeting",
            "article",
            "note",
          ],
          "type": "string",
        },
        "space": {
          "description": "Space slug the key is working in",
          "pattern": "^[a-z0-9][a-z0-9-]{0,62}$",
          "type": "string",
        },
        "text": {
          "minLength": 1,
          "type": "string",
        },
        "title": {
          "maxLength": 500,
          "type": "string",
        },
        "url": {
          "format": "uri",
          "type": "string",
        },
      },
      "required": [
        "space",
      ],
      "type": "object",
      "~standard": {
        "jsonSchema": {
          "input": [Function],
          "output": [Function],
        },
        "validate": [Function],
        "vendor": "zod",
        "version": 1,
      },
    },
    "name": "wikikit_ingest",
  },
  {
    "annotations": {
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false,
      "readOnlyHint": true,
    },
    "description": "Poll an ingest job started by wikikit_ingest. Terminal states: done (carries proposal_id) or failed (carries error.code/message).",
    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "ingest_id": {
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
          "type": "string",
        },
      },
      "required": [
        "ingest_id",
      ],
      "type": "object",
      "~standard": {
        "jsonSchema": {
          "input": [Function],
          "output": [Function],
        },
        "validate": [Function],
        "vendor": "zod",
        "version": 1,
      },
    },
    "name": "wikikit_ingest_status",
  },
  {
    "annotations": {
      "destructiveHint": true,
      "idempotentHint": true,
      "openWorldHint": false,
      "readOnlyHint": false,
    },
    "description": "Stage a structured ChangeProposal (concepts with claims/citations/relations, decisions) into the review gate. Nothing becomes visible until a reviewer with knowledge:approve explicitly approves it.",
    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "agent_meta": {
          "additionalProperties": {},
          "default": {},
          "type": "object",
        },
        "concepts": {
          "default": [],
          "items": {
            "additionalProperties": false,
            "properties": {
              "base_revision_id": {
                "anyOf": [
                  {
                    "format": "uuid",
                    "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                    "type": "string",
                  },
                  {
                    "type": "null",
                  },
                ],
              },
              "claims": {
                "default": [],
                "items": {
                  "additionalProperties": false,
                  "properties": {
                    "citations": {
                      "default": [],
                      "items": {
                        "additionalProperties": false,
                        "properties": {
                          "locator": {
                            "default": "",
                            "maxLength": 500,
                            "type": "string",
                          },
                          "quote": {
                            "minLength": 1,
                            "type": "string",
                          },
                          "source_id": {
                            "format": "uuid",
                            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                            "type": "string",
                          },
                        },
                        "required": [
                          "source_id",
                          "quote",
                        ],
                        "type": "object",
                      },
                      "type": "array",
                    },
                    "confidence": {
                      "default": 0.5,
                      "maximum": 1,
                      "minimum": 0,
                      "type": "number",
                    },
                    "object": {
                      "maxLength": 2000,
                      "minLength": 1,
                      "type": "string",
                    },
                    "predicate": {
                      "maxLength": 200,
                      "minLength": 1,
                      "type": "string",
                    },
                    "subject": {
                      "maxLength": 500,
                      "minLength": 1,
                      "type": "string",
                    },
                  },
                  "required": [
                    "subject",
                    "predicate",
                    "object",
                  ],
                  "type": "object",
                },
                "type": "array",
              },
              "markdown": {
                "minLength": 1,
                "type": "string",
              },
              "relations": {
                "default": [],
                "items": {
                  "additionalProperties": false,
                  "properties": {
                    "kind": {
                      "enum": [
                        "related",
                        "part_of",
                        "depends_on",
                        "contradicts",
                        "supersedes",
                      ],
                      "type": "string",
                    },
                    "to_slug": {
                      "pattern": "^[a-z0-9][a-z0-9-]{0,126}$",
                      "type": "string",
                    },
                  },
                  "required": [
                    "to_slug",
                    "kind",
                  ],
                  "type": "object",
                },
                "type": "array",
              },
              "slug": {
                "pattern": "^[a-z0-9][a-z0-9-]{0,126}$",
                "type": "string",
              },
              "summary": {
                "default": "",
                "maxLength": 4000,
                "type": "string",
              },
              "title": {
                "maxLength": 500,
                "minLength": 1,
                "type": "string",
              },
            },
            "required": [
              "slug",
              "title",
              "markdown",
            ],
            "type": "object",
          },
          "type": "array",
        },
        "decisions": {
          "default": [],
          "items": {
            "additionalProperties": false,
            "properties": {
              "alternatives": {
                "default": [],
                "items": {},
                "type": "array",
              },
              "context": {
                "minLength": 1,
                "type": "string",
              },
              "decision": {
                "minLength": 1,
                "type": "string",
              },
              "rationale": {
                "default": "",
                "type": "string",
              },
              "slug": {
                "pattern": "^[a-z0-9][a-z0-9-]{0,126}$",
                "type": "string",
              },
              "title": {
                "maxLength": 500,
                "minLength": 1,
                "type": "string",
              },
            },
            "required": [
              "slug",
              "title",
              "context",
              "decision",
            ],
            "type": "object",
          },
          "type": "array",
        },
        "input_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string",
        },
        "source_ids": {
          "default": [],
          "items": {
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
            "type": "string",
          },
          "type": "array",
        },
        "space": {
          "description": "Space slug the key is working in",
          "pattern": "^[a-z0-9][a-z0-9-]{0,62}$",
          "type": "string",
        },
        "summary": {
          "default": "",
          "maxLength": 4000,
          "type": "string",
        },
        "title": {
          "maxLength": 500,
          "minLength": 1,
          "type": "string",
        },
      },
      "required": [
        "title",
        "input_hash",
        "space",
      ],
      "type": "object",
      "~standard": {
        "jsonSchema": {
          "input": [Function],
          "output": [Function],
        },
        "validate": [Function],
        "vendor": "zod",
        "version": 1,
      },
    },
    "name": "wikikit_propose",
  },
]
`;

