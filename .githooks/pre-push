#!/usr/bin/env bash
# Runs the full gate before anything leaves this machine (`bun run gate`).
#
# Enable once per clone: bun run hooks:install   (sets core.hooksPath=.githooks)
#
# Why pre-push and not pre-commit: commits are cheap, local and often
# work-in-progress — gating them punishes the normal act of saving your work.
# A push is the first moment the code becomes someone else's problem, and it is
# rare enough to afford ~30s of checks.
#
# Deliberate bypasses (both are visible in the output, on purpose):
#   SKIP=integration,e2e git push    — run a subset
#   git push --no-verify             — skip the hook entirely
set -uo pipefail

# Nothing to check when the push deletes a ref.
if [ -t 0 ]; then
  :
else
  # stdin carries "<local ref> <local sha> <remote ref> <remote sha>" lines;
  # an all-zero local sha means a branch deletion.
  refs=$(cat)
  if [ -n "$refs" ] && ! printf '%s\n' "$refs" | grep -qv '^\S* 0\{40\} '; then
    echo "pre-push: branch deletion, nothing to verify"
    exit 0
  fi
fi

command -v bun >/dev/null 2>&1 || {
  echo "pre-push: bun not found — cannot run the gate. Install bun or push with --no-verify." >&2
  exit 1
}

exec bun run scripts/gate.ts
