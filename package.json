{
  "name": "wikikit",
  "version": "0.1.0",
  "description": "Headless AI-native knowledge system for humans and agents — Markdown-first knowledge in, structured and agent-ready knowledge out",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "bun": ">=1.1"
  },
  "scripts": {
    "dev": "bun --watch bin/wikikit.ts",
    "start": "bun bin/wikikit.ts",
    "migrate": "bun bin/wikikit.ts --migrate",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test test/unit test/contract",
    "test:unit": "bun test test/unit",
    "test:contract": "bun test test/contract",
    "test:integration": "bun test test/integration",
    "build:binary": "bash build-binary.sh",
    "gen:migrations": "bun scripts/gen-embedded-migrations.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pg": "^8.16.3",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.8.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/bun": "^1.2.0",
    "@types/pg": "^8.15.0",
    "eslint": "^9.30.0",
    "globals": "^17.7.0",
    "prettier": "^3.6.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0"
  },
  "author": "Mike Bild <mike@mikebild.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MikeBild/wikikit.git"
  },
  "homepage": "https://github.com/MikeBild/wikikit#readme",
  "bugs": {
    "url": "https://github.com/MikeBild/wikikit/issues"
  },
  "keywords": [
    "knowledge-base",
    "wiki",
    "ai-native",
    "headless",
    "mcp",
    "api-first",
    "markdown",
    "okf",
    "claims",
    "agents"
  ]
}
