# WikiKit configuration reference.
# Copy to .env for local overrides. In production (NODE_ENV=production) the
# variables marked REQUIRED must be set or the process refuses to boot.
# Full documentation: docs/CONFIGURATION.md

# --- Core ---
HOST=127.0.0.1
PORT=4060
# Public base URL used in Location headers, webhooks, and docs links.
WIKIKIT_PUBLIC_URL=https://wikikit.example.com
# REQUIRED in production. Postgres connection string (tables prefixed wk_).
DATABASE_URL=postgresql://user:pass@host:5432/wikikit

# --- Auth ---
# REQUIRED in production. HMAC pepper for hashing wk_ API keys at rest.
WIKIKIT_KEY_PEPPER=
# Optional: pin the bootstrap admin key (wk_...). Dev generates one at boot.
WIKIKIT_BOOTSTRAP_API_KEY=

# --- LLM (optional — LLM-free features work without a key) ---
ANTHROPIC_API_KEY=
# Point at a stub/proxy for tests; the Anthropic SDK honors this natively.
ANTHROPIC_BASE_URL=
WIKIKIT_MODEL_SYNTHESIS=claude-sonnet-5
WIKIKIT_MODEL_CLASSIFY=claude-haiku-4-5
WIKIKIT_MODEL_ANSWER=claude-sonnet-5

# --- Limits ---
WIKIKIT_MAX_BODY_BYTES=10485760
WIKIKIT_MAX_INGEST_TOKENS=100000
WIKIKIT_INGEST_CONCURRENCY=2

# --- Webhooks (Standard Webhooks outbox delivery) ---
WIKIKIT_WEBHOOK_POLL_MS=5000
WIKIKIT_WEBHOOK_TIMEOUT_MS=10000
WIKIKIT_WEBHOOK_MAX_ATTEMPTS=10
WIKIKIT_WEBHOOK_CIRCUIT_THRESHOLD=5
# Allow deliveries to private/loopback targets (default: true outside production).
WIKIKIT_WEBHOOK_ALLOW_PRIVATE=false

# --- HTTP ---
# Trust X-Forwarded-* headers (behind Caddy/nginx).
WIKIKIT_TRUST_PROXY=1

# --- MCP ---
WIKIKIT_MCP_SESSION_TTL_MS=1800000
WIKIKIT_MCP_MAX_SESSIONS=200

# --- Logging ---
LOG_LEVEL=info
