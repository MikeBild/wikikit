# WikiKit configuration reference.
# Copy to .env for local overrides. In production (NODE_ENV=production) the
# variables marked REQUIRED must be set or the process refuses to boot.
# Full documentation: docs/CONFIGURATION.md

# --- Core ---
HOST=127.0.0.1
PORT=4060
# Public base URL. Sole consumer: the MCP Origin allowlist (DNS-rebinding
# guard). Location headers are relative and webhooks use their own target URL.
WIKIKIT_PUBLIC_URL=https://wikikit.example.com
# REQUIRED in production. Postgres connection string (tables prefixed wk_).
DATABASE_URL=postgresql://user:pass@host:5432/wikikit

# --- Auth ---
# REQUIRED in production. HMAC pepper for hashing wk_ API keys at rest.
WIKIKIT_KEY_PEPPER=
# Optional: pin the bootstrap admin key (wk_...). Dev generates one at boot.
WIKIKIT_BOOTSTRAP_API_KEY=

# --- Deployment identity ---
DEPLOYMENT_ENVIRONMENT=production

# --- LLM (optional — LLM-free features work without a key) ---
# Which vendor the AI SDK routes to: anthropic | openai | google.
# Only the SELECTED provider's key is read; a mistyped value fails the boot.
WIKIKIT_LLM_PROVIDER=anthropic
# Set the one matching WIKIKIT_LLM_PROVIDER. Without it, ingest and query
# answer 503 llm_not_configured; every LLM-free feature keeps working.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
# Point at a stub/proxy for tests; honored when WIKIKIT_LLM_PROVIDER=anthropic.
ANTHROPIC_BASE_URL=
# Model ids are provider-specific — change them when switching provider.
WIKIKIT_MODEL_SYNTHESIS=claude-sonnet-5
WIKIKIT_MODEL_CLASSIFY=claude-haiku-4-5
WIKIKIT_MODEL_ANSWER=claude-sonnet-5

# --- Limits ---
WIKIKIT_MAX_BODY_BYTES=10485760
WIKIKIT_MAX_INGEST_TOKENS=100000
WIKIKIT_INGEST_CONCURRENCY=2
WIKIKIT_INGEST_LEASE_MS=900000
WIKIKIT_INGEST_HEARTBEAT_MS=30000

# --- Webhooks (Standard Webhooks outbox delivery) ---
WIKIKIT_WEBHOOK_POLL_MS=5000
WIKIKIT_WEBHOOK_TIMEOUT_MS=10000
WIKIKIT_WEBHOOK_MAX_ATTEMPTS=10
WIKIKIT_WEBHOOK_CIRCUIT_THRESHOLD=5
# Allow deliveries to private/loopback targets (default: true outside production).
WIKIKIT_WEBHOOK_ALLOW_PRIVATE=false

# --- HTTP ---
# Trust X-Forwarded-* headers (behind Caddy/nginx).
WIKIKIT_TRUST_PROXY=1

# --- MCP ---
WIKIKIT_MCP_SESSION_TTL_MS=1800000
WIKIKIT_MCP_MAX_SESSIONS=200
WIKIKIT_MCP_ELICITATION_TIMEOUT_MS=300000

# --- Privacy-safe product usage analytics (opt-in) ---
# Independent product-local HMAC secret. Raw ids/content are never persisted.
WIKIKIT_USAGE_TELEMETRY_ENABLED=false
WIKIKIT_USAGE_HMAC_SECRET=
# Raw event retention, 31..365 days. Downstream aggregate reports may live longer.
WIKIKIT_USAGE_RETENTION_DAYS=90

# --- MCP OAuth 2.1 (ChatGPT and other remote clients) ---
# Dynamic registration is required by clients that do not use a predefined id.
WIKIKIT_OAUTH_DCR_ENABLED=true
WIKIKIT_OAUTH_CODE_TTL_MS=600000
WIKIKIT_OAUTH_ACCESS_TOKEN_TTL_MS=3600000
WIKIKIT_OAUTH_REFRESH_TOKEN_TTL_MS=2592000000
# Preferred provider matrix. Enable one or more concurrently.
WIKIKIT_OAUTH_LOGIN_METHODS=api_key
# Legacy single-provider selector, used only when LOGIN_METHODS is unset.
WIKIKIT_OAUTH_LOGIN_PROVIDER=api_key
WIKIKIT_OAUTH_FIREBASE_PROJECT_ID=
WIKIKIT_OAUTH_FIREBASE_LOGIN_URL=
WIKIKIT_OAUTH_ALLOWED_EMAILS=
WIKIKIT_OAUTH_ALLOWED_SCOPES=knowledge:read,knowledge:propose
# JSON provider array; keep any client_secret outside version control.
WIKIKIT_OAUTH_OIDC_PROVIDERS=

# --- Logging ---
LOG_LEVEL=info
