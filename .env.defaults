# Safe development-only defaults. Ignored entirely when NODE_ENV=production.
# Precedence: process env > .env > .env.defaults (dev only).
HOST=127.0.0.1
PORT=4060
WIKIKIT_PUBLIC_URL=http://127.0.0.1:4060
DATABASE_URL=postgresql://postgres:wikikit-local@127.0.0.1:55442/wikikit
WIKIKIT_KEY_PEPPER=wikikit-local-key-pepper
# Empty in dev: a bootstrap admin key is generated at first boot and printed
# once to stdout. Set explicitly to pin it.
WIKIKIT_BOOTSTRAP_API_KEY=
DEPLOYMENT_ENVIRONMENT=development
WIKIKIT_LLM_PROVIDER=anthropic
# No default anywhere: LLM-free features (search/read/lint/export/import/review)
# work without a key; ingest/query answer 503 llm_not_configured. Only the key
# matching WIKIKIT_LLM_PROVIDER is read.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# ANTHROPIC_BASE_URL=
WIKIKIT_MODEL_SYNTHESIS=claude-sonnet-5
WIKIKIT_MODEL_CLASSIFY=claude-haiku-4-5
WIKIKIT_MODEL_ANSWER=claude-sonnet-5
WIKIKIT_MAX_BODY_BYTES=10485760
WIKIKIT_MAX_INGEST_TOKENS=100000
WIKIKIT_INGEST_CONCURRENCY=2
WIKIKIT_INGEST_LEASE_MS=900000
WIKIKIT_INGEST_HEARTBEAT_MS=30000
WIKIKIT_WEBHOOK_POLL_MS=1000
WIKIKIT_WEBHOOK_TIMEOUT_MS=10000
WIKIKIT_WEBHOOK_MAX_ATTEMPTS=10
WIKIKIT_WEBHOOK_CIRCUIT_THRESHOLD=5
WIKIKIT_WEBHOOK_ALLOW_PRIVATE=true
WIKIKIT_TRUST_PROXY=0
WIKIKIT_MCP_SESSION_TTL_MS=1800000
WIKIKIT_MCP_MAX_SESSIONS=200
WIKIKIT_MCP_ELICITATION_TIMEOUT_MS=300000
WIKIKIT_USAGE_TELEMETRY_ENABLED=false
WIKIKIT_USAGE_HMAC_SECRET=
WIKIKIT_USAGE_RETENTION_DAYS=90
WIKIKIT_OAUTH_DCR_ENABLED=true
WIKIKIT_OAUTH_CODE_TTL_MS=600000
WIKIKIT_OAUTH_ACCESS_TOKEN_TTL_MS=3600000
WIKIKIT_OAUTH_REFRESH_TOKEN_TTL_MS=2592000000
WIKIKIT_OAUTH_ALLOWED_SCOPES=knowledge:read,knowledge:propose
WIKIKIT_OAUTH_PROVIDERS=[{"protocol":"api_key","id":"api-key","label":"WikiKit API key"}]
LOG_LEVEL=info
